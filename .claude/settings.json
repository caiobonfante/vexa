{
  "permissions": {
    "allow": [
      "Skill(update-config)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/dima/dev/vexa-agentic-runtime/.claude/confidence-check.sh",
            "timeout": 30,
            "statusMessage": "Checking confidence protocol..."
          },
          {
            "type": "command",
            "command": "/home/dima/dev/2/system/hooks/persist-confidence.sh",
            "timeout": 10,
            "statusMessage": "Persisting verifications..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'session started'",
            "timeout": 5,
            "statusMessage": "Loading confidence protocol..."
          },
          {
            "type": "command",
            "command": "/home/dima/dev/2/system/hooks/inject-context.sh",
            "timeout": 10,
            "statusMessage": "Loading confidence state..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "echo 'Confidence Protocol ACTIVE | Stop hook ON | Gotchas: G1-G6'"
  }
}

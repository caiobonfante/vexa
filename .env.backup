# --- Vexa Environment ---
# Copy to repo root as .env:  cp deploy/env/env-example .env
# Then edit the REQUIRED fields below.

# ============================================================================
# REQUIRED — you MUST set these
# ============================================================================

# Transcription service
# Get a key at vexa.ai OR self-host services/transcription-service/ with GPU
TRANSCRIPTION_SERVICE_URL=http://172.17.0.1:8085/v1/audio/transcriptions
TRANSCRIPTION_SERVICE_TOKEN=32c59b9f654f1b6e376c6f020d79897d

# Dashboard source (absolute path to dashboard code)
# The dashboard is included at services/dashboard/ in this repo
DASHBOARD_PATH=/home/dima/dev/vexa-agentic-runtime/services/dashboard

# ============================================================================
# Ports — change these to avoid conflicts with other stacks
# ============================================================================
API_GATEWAY_HOST_PORT=8056
DASHBOARD_HOST_PORT=3001
TRANSCRIPTION_COLLECTOR_HOST_PORT=8123
POSTGRES_HOST_PORT=5438
MCP_HOST_PORT=18888
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# ============================================================================
# Defaults — work as-is for local dev
# ============================================================================

# Admin
ADMIN_API_TOKEN=changeme
ADMIN_TOKEN=changeme
INTERNAL_API_SECRET=dev-secret-for-testing

# Image tag for all services (G9: immutable tags, never :dev/:latest)
IMAGE_TAG=260405-1517

# Bot image (built by `make build`)
BOT_IMAGE_NAME=vexaai/vexa-bot:260405-1937

# Database (embedded postgres by default)
DB_NAME=vexa
DB_USER=postgres
DB_PASSWORD=postgres
# For external DB, uncomment:
# REMOTE_DB=true
# DB_HOST=your-postgres-host
# DB_PORT=5432

# Storage (embedded minio by default)
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vexa-access-key
MINIO_SECRET_KEY=vexa-secret-key
MINIO_BUCKET=vexa
MINIO_SECURE=false

# Local GPU transcription (uncomment to self-host)
# LOCAL_TRANSCRIPTION=true

# TTS uses Piper (local, no API key needed)
# Voice models auto-download from HuggingFace on first use

# Billing hooks (optional — for hosted service)
# POST_MEETING_HOOKS=https://your-billing-webhook
TELEGRAM_BOT_TOKEN=8573331281:AAEsEa-p4mgMe7bLYG0kcJXkTD6GEneUdCw
AGENT_API_URL=http://172.24.0.1:8100

# Claude Code CLI credentials (mounted into agent containers)
CLAUDE_CREDENTIALS_PATH=/home/dima/.claude/.credentials.json
CLAUDE_JSON_PATH=/home/dima/.claude.json
BOT_API_TOKEN=vxa_bot_QicCUtuu5V1sjrbWQlcroepLiMrk8mvF9eqR6DeF
BROWSER_IMAGE=vexaai/vexa-bot:260405-1937
VEXA_API_KEY=vxa_bot_SqQ4XXcd86xyVsKKLn48LkF3QLzqqSh95ovLUoUG

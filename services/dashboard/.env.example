# Required — must match the ports your compose stack exposes
# See features/agentic-runtime/README.md for port map
VEXA_API_URL=http://localhost:8066
VEXA_ADMIN_API_KEY=vexa-admin-token

# Admin API URL — must point to admin-api directly (NOT api-gateway)
# API key creation and webhook config go here
VEXA_ADMIN_API_URL=http://localhost:8067

# Agent API (for chat, workspace, scheduling)
AGENT_API_URL=http://localhost:8100

# WebSocket for live transcripts
NEXT_PUBLIC_VEXA_WS_URL=ws://localhost:8066/ws

# App URL and auth
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=vexa-agentic-dev-secret
JWT_SECRET=vexa-agentic-jwt-secret

# Optional: transcript sharing and docs URLs
# NEXT_PUBLIC_TRANSCRIPT_SHARE_BASE_URL=https://share.example.com
# NEXT_PUBLIC_BASE_URL=https://dashboard.example.com
# NEXT_PUBLIC_WEBAPP_URL=https://webapp.vexa.ai

# Optional: default bot config
# DEFAULT_BOT_NAME=Vexa - Open Source Bot

# Optional: AI assistant
# AI_MODEL=openai/gpt-4o
# AI_API_KEY=
# AI_BASE_URL=

# Optional: email authentication (magic link)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Optional: Google OAuth
# ENABLE_GOOGLE_AUTH=false
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Zoom OAuth
# ZOOM_OAUTH_CLIENT_ID=
# ZOOM_OAUTH_CLIENT_SECRET=
# ZOOM_OAUTH_REDIRECT_URI=
# ZOOM_OAUTH_STATE_SECRET=

# Optional: registration policy
# ALLOW_REGISTRATIONS=true
# ALLOWED_EMAIL_DOMAINS=

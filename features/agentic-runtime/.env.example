# Agentic Runtime -- Infrastructure Config

# Claude credentials (host paths -- bind-mounted into agent containers)
CLAUDE_CREDENTIALS_PATH=/home/dima/.claude/.credentials.json
CLAUDE_JSON_PATH=/home/dima/.claude.json

# Shared transcription service (reuse common instance)
TRANSCRIPTION_URL=http://localhost:8085/v1/audio/transcriptions
TRANSCRIPTION_TOKEN=

# Isolated stack ports (avoid collisions with vexa-restore)
REDIS_PORT=6389
POSTGRES_PORT=5458
CHAT_API_PORT=8100
MINIO_PORT=9020
MINIO_CONSOLE_PORT=9021

# Database
DB_NAME=vexa_agentic
DB_USER=postgres
DB_PASSWORD=postgres

# MinIO
MINIO_ACCESS_KEY=vexa-access-key
MINIO_SECRET_KEY=vexa-secret-key
MINIO_BUCKET=vexa-agentic

# Chat API
IDLE_TIMEOUT=300
LOG_LEVEL=INFO

# Telegram Bot
TELEGRAM_BOT_TOKEN=           # Get from @BotFather
CHAT_DEFAULT_USER_ID=dima     # All Telegram users share this workspace (single-user mode)
CHAT_USER_MAP={}              # Or map chat_ids: {"123456":"alice","789012":"bob"}

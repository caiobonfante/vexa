# Claude Code CLI credentials (mounted into agent containers)
# Point these to your host machine's Claude CLI auth files
CLAUDE_CREDENTIALS_PATH=/home/YOUR_USER/.claude/.credentials.json
CLAUDE_JSON_PATH=/home/YOUR_USER/.claude.json

# Service-to-service auth token (chat-api -> runtime-api, vexa CLI -> runtime-api)
BOT_API_TOKEN=

# Transcription service (Whisper) — runs externally, not in this compose stack
# On Linux: use Docker bridge gateway IP to reach host services
# On Mac/Windows: use host.docker.internal
TRANSCRIPTION_SERVICE_URL=http://172.17.0.1:8083
TRANSCRIPTION_SERVICE_TOKEN=

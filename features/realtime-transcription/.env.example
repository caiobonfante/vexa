# Realtime Transcription Feature — Environment Config
# Copy to .env and fill in actual values for your environment.
# .env is gitignored. .env.example is committed.

# --- Transcription service ---
TRANSCRIPTION_URL=http://localhost:8085/v1/audio/transcriptions
TRANSCRIPTION_TOKEN=
MODEL_SIZE=large-v3-turbo
COMPUTE_TYPE=int8
DEVICE=cuda
BEAM_SIZE=5
VAD_FILTER=true
VAD_FILTER_THRESHOLD=0.5
NO_SPEECH_THRESHOLD=0.6
MAX_CONCURRENT_TRANSCRIPTIONS=2

# --- Pipeline params (SpeakerStreamManager) ---
SUBMIT_INTERVAL=3
CONFIRM_THRESHOLD=3
MIN_AUDIO_DURATION=3
MAX_BUFFER_DURATION=120
IDLE_TIMEOUT_SEC=15
MAX_SPEECH_DURATION_SEC=15

# --- TTS service (for collection runs) ---
TTS_URL=http://localhost:8002/v1/audio/speech
TTS_VOICE=en_US-lessac-medium

# --- Platform ---
PLATFORM=ms-teams

# --- Stack endpoints ---
# Must match actual port from: docker compose ps api-gateway
API_GATEWAY_URL=http://localhost:8056
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql://postgres:postgres@localhost:5448/vexa_restore
BOT_IMAGE_NAME=vexaai/vexa-bot:dev

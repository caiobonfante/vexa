# Calendar Integration Feature — Environment Config
# Copy to .env and fill in actual values for your environment.
# .env is gitignored. .env.example is committed.

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3011/api/auth/callback/google

# --- Calendar service ---
CALENDAR_SERVICE_URL=http://localhost:8071
CALENDAR_SYNC_INTERVAL=300
JOIN_MINUTES_BEFORE=1
CALENDAR_WEBHOOK_URL=

# --- Token encryption ---
TOKEN_ENCRYPTION_KEY=

# --- Stack endpoints ---
API_GATEWAY_URL=http://localhost:8066
ADMIN_API_URL=http://localhost:8067
POSTGRES_URL=postgresql://postgres:postgres@localhost:5448/vexa_restore

# --- Auth ---
API_TOKEN=
ADMIN_TOKEN=changeme

# Post-Meeting Transcription Feature — Environment Config
# Copy to .env and fill in actual values for your environment.
# .env is gitignored. .env.example is committed.

# --- Platform ---
PLATFORM=ms-teams

# --- Stack endpoints ---
API_GATEWAY_URL=http://localhost:8066
MEETING_API_URL=http://localhost:8066
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql://postgres:postgres@localhost:5448/vexa_restore
ADMIN_PORT=8057

# --- Transcription service (runs separately, GPU) ---
# Local: transcription-service docker-compose exposes nginx at 8083
# Docker network: http://transcription-service:80
TRANSCRIPTION_SERVICE_URL=http://localhost:8083/v1/audio/transcriptions

# --- Storage (MinIO) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vexa-recordings

# --- TTS service (for collection runs) ---
TTS_URL=http://localhost:8002/v1/audio/speech

# --- Speaker tokens (one per speaker bot) ---
# Recorder uses API_TOKEN (user 1)
API_TOKEN=vxa_user_pZqJ5dEQK47Mc7YeVTR53wAefBCs7Nf6d0fHbHs8
ALICE_TOKEN=vxa_bot_db0x5tx0PRWvXYCXaBOTNEmjgpJPwZysIEUsTH94
